# SmartAgriCare Backend Configuration
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database (choose ONE)
# Option 1: MongoDB Atlas (production)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# IMPORTANT: URL-encode special characters in password (@ -> %40, # -> %23, etc.)
MONGODB_URI=

# Option 2: SQLite (local development - used when MONGODB_URI is empty)
# No configuration needed - database stored in backend/data/smartagricare.db

# Email (Gmail SMTP for password reset)
# 1. Go to myaccount.google.com -> Security -> 2-Step Verification -> App passwords
# 2. Create an app password for "SmartAgriCare"
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# LLM APIs for Voice Assistant (cascade: Groq -> Gemini -> SambaNova)
# Groq (primary) - https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (fallback) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AI...
GEMINI_MODEL=gemini-2.0-flash

# SambaNova (last resort) - https://cloud.sambanova.ai
SAMBANOVA_API_KEY=
SAMBANOVA_MODEL=Meta-Llama-3.1-70B-Instruct

# ML Service (disease detection)
ML_SERVICE_URL=http://localhost:5001

# CORS Origins (comma-separated, for development)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
